{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumorix Null District",
  "version": "0.1.0-beta.5",
  "identifier": "com.lumorix.nulldistrict",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lumorix: Null District",
        "width": 1280,
        "height": 720,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "Game",
    "shortDescription": "Dark 2D online mystery RPG beta.",
    "longDescription": "Lumorix: Null District is a dark 2D side-view online mystery RPG beta with co-op exploration, action combat, quests, inventory and fair cosmetics-only monetization.",
    "createUpdaterArtifacts": false,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "TAURI_UPDATE_PUBLIC_KEY_PLACEHOLDER",
      "endpoints": [
        "https://github.com/lumorix/nulldistrict/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
